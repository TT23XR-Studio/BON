{
  "compilerOptions": {
    "target": "ESNEXT",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
  },
  "include": ["*.ts", "../packages/bon-ts/src/**/*.ts"]
}
